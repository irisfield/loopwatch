{
  "name": "@irisfield/loopwatch-react",
  "version": "0.0.1",
  "description": "React hooks for loopwatch event-loop measurement.",
  "type": "module",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs"
    }
  },
  "sideEffects": false,
  "files": ["dist", "README.md", "LICENSE"],
  "license": "MIT",
  "peerDependencies": {
    "react": ">=16.8.0",
    "@irisfield/loopwatch": "^0.0.1"
  },
  "devDependencies": {
    "@irisfield/loopwatch": "workspace:*",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@testing-library/react": "^16.0.0"
  },
  "scripts": {
    "build": "rollup -c",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "lint": "eslint --cache src",
    "prepublishOnly": "bun run lint && bun run type-check && bun run build && bun run test"
  }
}
