{
  "name": "loopwatch",
  "version": "1.0.0",
  "description": "A tiny TypeScript library that measures JavaScript event-loop responsiveness in the browser.",
  "type": "module",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs"
    },
    "./measure-lag": {
      "types": "./dist/measure-lag.d.ts",
      "import": "./dist/measure-lag.mjs"
    },
    "./long-tasks": {
      "types": "./dist/long-tasks.d.ts",
      "import": "./dist/long-tasks.mjs"
    },
    "./loop-monitor": {
      "types": "./dist/loop-monitor.d.ts",
      "import": "./dist/loop-monitor.mjs"
    },
    "./compare-reports": {
      "types": "./dist/compare-reports.d.ts",
      "import": "./dist/compare-reports.mjs"
    }
  },
  "sideEffects": false,
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "rollup -c",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:browser": "playwright test",
    "test:browser:install": "playwright install chromium",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint --cache src test browser-smoke playwright.config.ts",
    "format": "prettier --write \"{src,test,browser-smoke}/**/*.ts\" \"playwright.config.ts\" --list-different",
    "test:pack": "bun run build && node scripts/smoke-dist.mjs && bun pm pack --dry-run",
    "prepublishOnly": "bun run lint && bun run type-check && bun run test && bun run build",
    "prepare": "[ -x node_modules/.bin/husky ] && node_modules/.bin/husky || true"
  },
  "engines": {
    "node": ">=22"
  },
  "license": "MIT",
  "homepage": "https://github.com/irisfield/loopwatch#readme",
  "bugs": {
    "url": "https://github.com/irisfield/loopwatch/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/irisfield/loopwatch.git"
  },
  "keywords": [
    "event-loop",
    "performance",
    "browser",
    "long-task",
    "raf",
    "performance-observer",
    "typescript",
    "monitoring"
  ],
  "lint-staged": {
    "{src,test}/**/*.ts": [
      "eslint --cache --fix",
      "prettier --write"
    ]
  },
  "prettier": {
    "singleQuote": false,
    "semi": true,
    "printWidth": 100
  },
  "devDependencies": {
    "@rollup/plugin-terser": "^1.0.0",
    "@rollup/plugin-typescript": "^12.3.0",
    "@playwright/test": "^1.60.0",
    "@types/node": "^25.9.0",
    "@vitest/coverage-v8": "^4.1.6",
    "eslint": "^10.4.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import-x": "^4.16.2",
    "eslint-plugin-unicorn": "^64.0.0",
    "happy-dom": "^20.9.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.5",
    "prettier": "^3.8.3",
    "rollup": "^4.60.4",
    "rollup-plugin-dts": "^6.4.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.4",
    "vitest": "^4.1.6"
  }
}
