{
  "name": "loopwatch",
  "version": "0.1.0",
  "description": "A tiny TypeScript library that measures JavaScript event-loop responsiveness in the browser.",
  "type": "module",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs"
    }
  },
  "sideEffects": false,
  "files": ["dist", "README.md", "LICENSE"],
  "scripts": {
    "build": "rollup -c",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint --cache src test",
    "format": "prettier --write \"{src,test}/**/*.ts\"",
    "prepublishOnly": "bun run lint && bun run type-check && bun run test && bun run build"
  },
  "engines": {
    "node": ">=18"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/irisfield/loopwatch.git"
  },
  "keywords": [
    "event-loop",
    "performance",
    "browser",
    "long-task",
    "raf",
    "microtask",
    "performance-observer",
    "typescript",
    "monitoring"
  ],
  "prettier": {
    "singleQuote": false,
    "semi": true,
    "printWidth": 100
  },
  "devDependencies": {
    "@rollup/plugin-terser": "^1.0.0",
    "@rollup/plugin-typescript": "^12.3.0",
    "@types/node": "^25.6.2",
    "@vitest/coverage-v8": "^4.1.5",
    "eslint": "^10.3.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import-x": "^4.16.2",
    "eslint-plugin-unicorn": "^64.0.0",
    "happy-dom": "^20.9.0",
    "prettier": "^3.8.3",
    "rollup": "^4.60.3",
    "rollup-plugin-dts": "^6.4.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.2",
    "vitest": "^4.1.5"
  }
}
